# Copy to .env and fill in values. .env is gitignored.
#
# PostgreSQL connection string (required to run the app).
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/orbit_dev?sslmode=disable

# development | production — may control logging, error detail exposure, etc.
ORBIT_ENV=development

# When true, JSON error responses may include a "detail" field (good for local dev).
# Set to false in production if you do not want to leak internal errors to clients.
SHOW_ERROR_DETAIL=true
